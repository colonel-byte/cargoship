{
  "$defs": {
    "DistroCreateOptions": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "cache_path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "DistroDeployOptions": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "retries": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "DistroOptions": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "create": {
          "$ref": "#/$defs/DistroCreateOptions"
        },
        "deploy": {
          "$ref": "#/$defs/DistroDeployOptions"
        },
        "oci_concurrency": {
          "type": "integer"
        }
      },
      "type": "object"
    }
  },
  "$id": "https://github.com/colonel-byte/zarf-distro/src/types/distro-config",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "patternProperties": {
    "^x-": {}
  },
  "properties": {
    "distro": {
      "$ref": "#/$defs/DistroOptions"
    },
    "log_format": {
      "default": "console",
      "enum": [
        "console",
        "json",
        "dev"
      ],
      "type": "string"
    },
    "log_level": {
      "default": "info",
      "enum": [
        "warn",
        "info",
        "debug",
        "trace"
      ],
      "type": "string"
    },
    "zarf_cache": {
      "type": "string"
    }
  },
  "type": "object"
}
