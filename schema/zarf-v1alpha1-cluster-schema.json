{
  "$defs": {
    "Localhost": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "enabled": {
          "description": "Enabled must be true for the connection to be valid",
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "OpenSSH": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "address": {
          "description": "Address of the remote host",
          "format": "hostname",
          "type": "string"
        },
        "configPath": {
          "description": "Path to SSH config file",
          "type": "string"
        },
        "disableMultiplexing": {
          "default": false,
          "description": "Disable SSH connection multiplexing",
          "type": "boolean"
        },
        "keyPath": {
          "description": "Path to SSH private key",
          "type": "string"
        },
        "options": {
          "$ref": "#/$defs/OpenSSHOptions",
          "description": "Additional SSH options as key-value pairs"
        },
        "port": {
          "description": "Optional SSH port",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "user": {
          "description": "Optional SSH user",
          "type": "string"
        }
      },
      "required": [
        "address"
      ],
      "type": "object"
    },
    "OpenSSHOptions": {
      "type": "object"
    },
    "SSH": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "address": {
          "description": "Address of the remote host (IP or hostname)",
          "format": "hostname",
          "type": "string"
        },
        "bastion": {
          "$ref": "#/$defs/SSH",
          "description": "Optional bastion host"
        },
        "hostKey": {
          "description": "Optional known host key fingerprint",
          "type": "string"
        },
        "keyPath": {
          "description": "Optional path to private key",
          "type": "string"
        },
        "port": {
          "default": 22,
          "description": "SSH port",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "user": {
          "default": "root",
          "description": "User to log in as",
          "type": "string"
        }
      },
      "required": [
        "address",
        "user",
        "port"
      ],
      "type": "object"
    },
    "WinRM": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "address": {
          "description": "Address of the remote host",
          "format": "hostname",
          "type": "string"
        },
        "bastion": {
          "$ref": "#/$defs/SSH",
          "description": "Optional SSH bastion"
        },
        "caCertPath": {
          "description": "Path to CA certificate",
          "type": "string"
        },
        "certPath": {
          "description": "Path to client certificate",
          "type": "string"
        },
        "insecure": {
          "default": false,
          "description": "Accept invalid TLS certificates",
          "type": "boolean"
        },
        "keyPath": {
          "description": "Path to client key",
          "type": "string"
        },
        "password": {
          "description": "Password for WinRM authentication",
          "type": "string"
        },
        "port": {
          "default": 5985,
          "description": "WinRM port",
          "maximum": 65535,
          "minimum": 1,
          "type": "integer"
        },
        "tlsServerName": {
          "description": "TLS server name override",
          "format": "hostname",
          "type": "string"
        },
        "useHttps": {
          "default": false,
          "description": "Use HTTPS for WinRM",
          "type": "boolean"
        },
        "useNtlm": {
          "default": false,
          "description": "Use NTLM authentication",
          "type": "boolean"
        },
        "user": {
          "default": "Administrator",
          "description": "User to authenticate as",
          "minLength": 3,
          "type": "string"
        }
      },
      "required": [
        "address",
        "user",
        "port"
      ],
      "type": "object"
    },
    "ZarfClusterConfig": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "profiles": {
          "items": {
            "$ref": "#/$defs/ZarfClusterProfiles"
          },
          "type": "array"
        },
        "registries": {
          "items": {
            "$ref": "#/$defs/ZarfClusterRegistries"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "rke2",
            "k3s"
          ],
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ZarfClusterFiles": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "data": {
          "type": "string"
        },
        "dst": {
          "type": "string"
        },
        "dstDir": {
          "type": "string"
        },
        "group": {
          "examples": [
            "root"
          ],
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "perm": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "user": {
          "examples": [
            "root"
          ],
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ZarfClusterProfiles": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "engineConfig": {
          "type": "object"
        },
        "kubeletConfig": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ZarfClusterRegistries": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "auth": {
          "$ref": "#/$defs/ZarfClusterRegistryAuth"
        },
        "name": {
          "type": "string"
        },
        "proxy": {
          "$ref": "#/$defs/ZarfClusterRegistryProxy"
        }
      },
      "required": [
        "name",
        "proxy"
      ],
      "type": "object"
    },
    "ZarfClusterRegistryAuth": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "pass": {
          "type": "string"
        },
        "token": {
          "type": "string"
        },
        "user": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "ZarfClusterRegistryProxy": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    },
    "ZarfClusterSpec": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "config": {
          "$ref": "#/$defs/ZarfClusterConfig"
        },
        "hosts": {
          "$ref": "#/$defs/ZarfHosts"
        }
      },
      "required": [
        "config",
        "hosts"
      ],
      "type": "object"
    },
    "ZarfDistroMetadata": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z0-9][a-z0-9\\-]*$",
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ZarfHost": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "binaryPath": {
          "type": "string"
        },
        "dataDir": {
          "type": "string"
        },
        "environment": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/ZarfClusterFiles"
          },
          "type": "array"
        },
        "hostname": {
          "type": "string"
        },
        "installPath": {
          "type": "string"
        },
        "kubeletRootDir": {
          "type": "string"
        },
        "localhost": {
          "$ref": "#/$defs/Localhost"
        },
        "openSSH": {
          "$ref": "#/$defs/OpenSSH"
        },
        "privateAddress": {
          "type": "string"
        },
        "privateInterface": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "role": {
          "enum": [
            "controller",
            "'controller+worker'",
            "single",
            "worker"
          ],
          "type": "string"
        },
        "ssh": {
          "$ref": "#/$defs/SSH"
        },
        "winRm": {
          "$ref": "#/$defs/WinRM"
        }
      },
      "required": [
        "role",
        "hostname"
      ],
      "type": "object"
    },
    "ZarfHosts": {
      "items": {
        "$ref": "#/$defs/ZarfHost"
      },
      "type": "array"
    }
  },
  "$id": "https://github.com/colonel-byte/zarf-distro/src/api/zarf.dev/v1alpha1/cluster/zarf-cluster",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "patternProperties": {
    "^x-": {}
  },
  "properties": {
    "apiVersion": {
      "enum": [
        "zarf.dev/v1alpha1"
      ],
      "type": "string"
    },
    "kind": {
      "enum": [
        "ZarfCluster"
      ],
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ZarfDistroMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ZarfClusterSpec"
    }
  },
  "required": [
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
