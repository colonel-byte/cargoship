{
  "$defs": {
    "OpenSSH": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "address": {
          "type": "string"
        },
        "configPath": {
          "type": "string"
        },
        "disableMultiplexing": {
          "type": "boolean"
        },
        "keyPath": {
          "type": "string"
        },
        "options": {
          "$ref": "#/$defs/OpenSSHOptions"
        },
        "port": {
          "type": "integer"
        },
        "user": {
          "type": "string"
        }
      },
      "required": [
        "address"
      ],
      "type": "object"
    },
    "OpenSSHOptions": {
      "type": "object"
    },
    "ZarfClusterConfig": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "profiles": {
          "items": {
            "$ref": "#/$defs/ZarfClusterProfiles"
          },
          "type": "array"
        },
        "registries": {
          "items": {
            "$ref": "#/$defs/ZarfClusterRegistries"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "rke2",
            "k3s"
          ],
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "ZarfClusterFiles": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "data": {
          "type": "string"
        },
        "dst": {
          "type": "string"
        },
        "dstDir": {
          "type": "string"
        },
        "group": {
          "examples": [
            "root"
          ],
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "perm": {
          "type": "string"
        },
        "src": {
          "type": "string"
        },
        "user": {
          "examples": [
            "root"
          ],
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ZarfClusterHosts": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "dataDir": {
          "type": "string"
        },
        "environment": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/ZarfClusterFiles"
          },
          "type": "array"
        },
        "hostname": {
          "type": "string"
        },
        "kubeletRootDir": {
          "type": "string"
        },
        "privateAddress": {
          "type": "string"
        },
        "privateInterface": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "role": {
          "enum": [
            "controller",
            "worker"
          ],
          "type": "string"
        },
        "ssh": {
          "$ref": "#/$defs/OpenSSH"
        }
      },
      "required": [
        "role",
        "hostname",
        "ssh"
      ],
      "type": "object"
    },
    "ZarfClusterProfiles": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "engineConfig": {
          "type": "object"
        },
        "kubeletConfig": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "ZarfClusterRegistries": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "auth": {
          "$ref": "#/$defs/ZarfClusterRegistryAuth"
        },
        "name": {
          "type": "string"
        },
        "proxy": {
          "$ref": "#/$defs/ZarfClusterRegistryProxy"
        }
      },
      "required": [
        "name",
        "proxy"
      ],
      "type": "object"
    },
    "ZarfClusterRegistryAuth": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "pass": {
          "type": "string"
        },
        "token": {
          "type": "string"
        },
        "user": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "ZarfClusterRegistryProxy": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    },
    "ZarfClusterSpec": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "config": {
          "$ref": "#/$defs/ZarfClusterConfig"
        },
        "hosts": {
          "items": {
            "$ref": "#/$defs/ZarfClusterHosts"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "config",
        "hosts"
      ],
      "type": "object"
    },
    "ZarfDistroMetadata": {
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "description": {
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z0-9][a-z0-9\\-]*$",
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/colonel-byte/zarf-distro/src/api/v1alpha1/zarf-cluster",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "patternProperties": {
    "^x-": {}
  },
  "properties": {
    "apiVersion": {
      "enum": [
        "zarf.dev/v1alpha1"
      ],
      "type": "string"
    },
    "kind": {
      "enum": [
        "ZarfCluster"
      ],
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ZarfDistroMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ZarfClusterSpec"
    }
  },
  "required": [
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
